#[pyfunction(name = "__getattr__")]
fn module_getattr(name: &str) -> PyResult<String> {
    match name {
        "__version__" => Ok("{{ project_version }}".to_string()),
        _ => Err(PyAttributeError::new_err(format!(
            "module has no attribute {name:?}"
        ))),
    }
}

fn workspace_for_function_impl(py: Python<'_>, function_name: &str) -> PyResult<Py<Workspace>> {
    match function_name {
{% for codegen in codegens %}
{% if codegen.python_name == codegen.function_name %}
        "{{ codegen.python_name }}" => {
{% else %}
        "{{ codegen.python_name }}" | "{{ codegen.function_name }}" => {
{% endif %}
            let mut values = Vec::with_capacity({{ codegen.workspace_size }});
            values.resize({{ codegen.workspace_size }}, 0.0_{{ scalar_type }});
            Py::new(
                py,
                Workspace {
                    function_name: "{{ codegen.python_name }}",
                    values,
                },
            )
        }
{% endfor %}
        _ => Err(PyValueError::new_err(format!(
            "unknown generated function {function_name:?}"
        ))),
    }
}

fn function_info_impl(py: Python<'_>, function_name: &str) -> PyResult<Py<PyAny>> {
    match function_name {
{% for codegen in codegens %}
{% if codegen.python_name == codegen.function_name %}
        "{{ codegen.python_name }}" => {
{% else %}
        "{{ codegen.python_name }}" | "{{ codegen.function_name }}" => {
{% endif %}
            let metadata = gradgen_low_level::{{ codegen.function_name }}_meta();
            build_function_info(py, "{{ codegen.python_name }}", metadata)
        }
{% endfor %}
        _ => Err(PyValueError::new_err(format!(
            "unknown generated function {function_name:?}"
        ))),
    }
}

fn call_impl(
    py: Python<'_>,
    function_name: &str,
    inputs: &Bound<'_, PyTuple>,
) -> PyResult<Py<PyAny>> {
    match function_name {
{% for codegen in codegens %}
{% if codegen.python_name == codegen.function_name %}
        "{{ codegen.python_name }}" => call_{{ codegen.function_name }}_from_tuple_impl(py, inputs),
{% else %}
        "{{ codegen.python_name }}" | "{{ codegen.function_name }}" => {
            call_{{ codegen.function_name }}_from_tuple_impl(py, inputs)
        }
{% endif %}
{% endfor %}
        _ => Err(PyValueError::new_err(format!(
            "unknown generated function {function_name:?}"
        ))),
    }
}

