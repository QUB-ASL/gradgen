        return Err(PyValueError::new_err(format!(
            "workspace expected at least {}",
            metadata.workspace_size
        )));
    }

{% for output_index in range(codegen.output_names|length) %}
    let mut output_{{ output_index }} = [0.0_{{ scalar_type }}; {{ codegen.output_sizes[output_index] }}];
{% endfor %}

    gradgen_low_level::{{ codegen.function_name }}(
{% for input_index in range(codegen.input_names|length) %}
        &input_{{ input_index }}[..],
{% endfor %}
{% for output_index in range(codegen.output_names|length) %}
        &mut output_{{ output_index }}[..],
{% endfor %}
        workspace.values.as_mut_slice(),
    )
    .map_err(pyerr_from_gradgen_error)?;

    let result = PyDict::new(py);
{% if codegen.output_names|length == 1 %}
    result.set_item(
        metadata.output_names[0],
        wrap_output(py, &output_0)?,
    )?;
    Ok(result.into_any().unbind())
{% else %}
{% for output_index in range(codegen.output_names|length) %}
    result.set_item(
        metadata.output_names[{{ output_index }}],
        wrap_output(py, &output_{{ output_index }})?,
    )?;
{% endfor %}
    Ok(result.into_any().unbind())
{% endif %}
}

fn call_{{ codegen.function_name }}_from_tuple_impl(
    py: Python<'_>,
    inputs: &Bound<'_, PyTuple>,
) -> PyResult<Py<PyAny>> {
    let metadata = gradgen_low_level::{{ codegen.function_name }}_meta();
    let expected_arg_count = metadata.input_sizes.len() + 1;
    if inputs.len() != expected_arg_count {
        return Err(PyValueError::new_err(format!(
            "{{ codegen.python_name }} expected {expected_arg_count} arguments including workspace"
        )));
    }

{% for input_index in range(codegen.input_names|length) %}
    let input_{{ input_index }} = extract_values(
        &inputs.get_item({{ input_index }})?,
        metadata.input_sizes[{{ input_index }}],
        metadata.input_names[{{ input_index }}],
    )?;
{% endfor %}

    let workspace = inputs
        .get_item({{ codegen.input_names|length }})?
        .extract::<PyRefMut<'_, Workspace>>()?;
    call_{{ codegen.function_name }}_impl(
        py,
{% for input_index in range(codegen.input_names|length) %}
        input_{{ input_index }},
{% endfor %}
        workspace,
    )
}

