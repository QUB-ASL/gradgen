use std::hint::black_box;
use std::time::Instant;

use {{ generated_crate_name }}::{
    {{ function_name }},
};

fn main() -> Result<(), Box<dyn std::error::Error>> {
    const TIMING_RUNS: usize = {{ timing_runs }};
    const COST_OUTPUT_LEN: usize = {{ cost_output_size }};
    const GRAD_OUTPUT_LEN: usize = {{ gradient_output_size }};
    const WORKSPACE_LEN: usize = {{ workspace_size }};

    let x0 = [
        1.0_{{ scalar_type }},
        -0.5_{{ scalar_type }},
        0.2_{{ scalar_type }},
        2.0_{{ scalar_type }},
    ];
    let u_seq = vec![
        0.05_{{ scalar_type }},
        -0.02_{{ scalar_type }},
    ]
    .repeat({{ horizon }});
    let p = [
        0.2_{{ scalar_type }},
        -0.1_{{ scalar_type }},
        0.05_{{ scalar_type }},
        1.8_{{ scalar_type }},
    ];
    let mut cost = [0.0_{{ scalar_type }}; COST_OUTPUT_LEN];
    let mut grad = [0.0_{{ scalar_type }}; GRAD_OUTPUT_LEN];
    let mut work = [0.0_{{ scalar_type }}; WORKSPACE_LEN];
    let mut checksum = 0.0_f64;

    let start = Instant::now();
    for _run in 0..TIMING_RUNS {
        {{ function_name }}(
            black_box(&x0),
            black_box(&u_seq),
            black_box(&p),
            black_box(&mut cost),
            black_box(&mut grad),
            black_box(&mut work),
        )
        .map_err(|error| std::io::Error::other(format!("{error:?}")))?;
        checksum += f64::from(cost[0]) + f64::from(grad[0]);
    }

    black_box(checksum);
    let total_ms = start.elapsed().as_secs_f64() * 1.0e3;
    println!("{:.6}", total_ms / TIMING_RUNS as f64);
    Ok(())
}
